# === OpenRouter ===
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY

# Comma-separated list of free models — OpenRouter tries each in order (route: fallback)
# Add/remove models from https://openrouter.ai/models?q=:free
OPENROUTER_MODELS=deepseek/deepseek-v4-flash:free,qwen/qwen3-next-80b-a3b-instruct:free,nvidia/nemotron-3-super-120b-a12b:free,meta-llama/llama-3.3-70b-instruct:free,google/gemma-4-31b-it:free,nousresearch/hermes-3-llama-3.1-405b:free,openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,minimax/minimax-m2.5:free

# === API Security ===
# Any strong random string — the Android app must send this as the X-API-Key header
API_KEY=REPLACE_WITH_A_STRONG_SECRET

# === Session ===
# How long (minutes) a ref_code stays valid before expiring
SESSION_TTL_MINUTES=30
# How many Q&A pairs to remember per conversation (each turn = ~100-200 extra tokens)
CONVERSATION_MAX_TURNS=3

# === Knowledge Base ===
# Folder containing your .md knowledge base files
KB_FOLDER=KB

# === CORS ===
# Comma-separated origins allowed to call this API, or * for all
ALLOWED_ORIGINS=*

# === Firebase ===
# Download Service Account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate new key
#
# LOCAL: place the JSON file in the project root, set path below
FIREBASE_SERVICE_ACCOUNT=service-account.json
#
# CLOUD (Render, Railway, etc.): base64-encode the JSON file and paste the result.
# Base64 avoids all newline/quote corruption issues that occur when pasting raw JSON.
#
# Windows PowerShell:
#   [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("service-account.json")) | Set-Clipboard
# macOS/Linux:
#   base64 service-account.json | tr -d '\n' | pbcopy
#
# Then paste the copied string as the value below:
# FIREBASE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6...
#
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PROJECT_NUMBER=your-project-number
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_APP_ID=your-android-app-id
FIREBASE_REGION=europe-west1